# Postgres in production (Render provides this automatically when you attach
# a database). Falls back to a local SQLite file if unset -- handy for dev.
DATABASE_URL=postgresql://user:password@localhost:5432/transit_hub

CORS_ORIGINS=http://localhost:5173

ENABLE_SCHEDULER=true
INGEST_INTERVAL_SECONDS=30

# Optional shared secret for POST /api/ingest/run. Leave unset to disable
# the check (fine for a portfolio demo with no sensitive data behind it).
INGEST_TRIGGER_SECRET=
